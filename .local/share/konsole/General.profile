[Appearance]
AntiAliasFonts=true
BoldIntense=false
ColorScheme=Twilight-Dark - terminal.sexy
Font=Source Code Pro,10,-1,5,25,0,0,0,0,0,Light
UseFontLineChararacters=false

[Cursor Options]
